<section class="fiber-link-dashboard">
  <header class="fiber-link-dashboard__header">
    <h2>Fiber Link Dashboard</h2>
    <p>Track your balance, payment progress, and recent tip activity from Discourse.</p>
  </header>

  {{#if this.model.summaryErrorMessage}}
    <p class="fiber-link-dashboard__alert is-error">
      Failed to load dashboard data: {{this.model.summaryErrorMessage}}
    </p>
  {{/if}}

  <section class="fiber-link-dashboard__metrics">
    <article class="fiber-link-dashboard__metric-card">
      <p class="fiber-link-dashboard__metric-label">Available Balance</p>
      {{#if this.model.isSummaryLoading}}
        <p class="fiber-link-dashboard__metric-value">Loading…</p>
      {{else}}
        <p class="fiber-link-dashboard__metric-value">
          {{this.model.balance}} {{this.model.balanceAsset}}
        </p>
      {{/if}}
    </article>

    <article class="fiber-link-dashboard__metric-card">
      <p class="fiber-link-dashboard__metric-label">Awaiting Payment</p>
      <p class="fiber-link-dashboard__metric-value">{{this.model.pendingTipCount}}</p>
    </article>

    <article class="fiber-link-dashboard__metric-card">
      <p class="fiber-link-dashboard__metric-label">Paid</p>
      <p class="fiber-link-dashboard__metric-value">{{this.model.settledTipCount}}</p>
    </article>

    <article class="fiber-link-dashboard__metric-card">
      <p class="fiber-link-dashboard__metric-label">Failed</p>
      <p class="fiber-link-dashboard__metric-value">{{this.model.failedTipCount}}</p>
    </article>
  </section>

  <div class="fiber-link-dashboard__content-grid">
    <FiberLinkWithdrawalPanel />

    <section class="fiber-link-dashboard__activity">
      <div class="fiber-link-dashboard__activity-header">
        <h3>Recent Tips</h3>
        <p class="fiber-link-dashboard__meta">
          {{#if this.model.generatedAt}}
            Generated: {{this.model.generatedAt}}
          {{/if}}
          {{#if this.model.refreshedAt}}
            · Refreshed: {{this.model.refreshedAt}}
          {{/if}}
        </p>
      </div>

      <FiberLinkTipFeed
        @tips={{this.model.tipFeedItems}}
        @isLoading={{this.model.isFeedLoading}}
        @errorMessage={{this.model.feedErrorMessage}}
      />
    </section>
  </div>
</section>
